{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "nebulosa",
	"version": "0.1.1",
	"identifier": "io.tiagohm.nebulosa",
	"build": {
		"beforeDevCommand": "bun run start",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist/nebulosa/browser"
	},
	"app": {
		"windows": [
			{
				"title": "Nebulosa",
				"width": 320,
				"height": 416,
				"titleBarStyle": "Transparent",
				"decorations": false,
				"maximizable": false,
				"resizable": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"resources": ["api.jar"]
	}
}
